# VEE-REAL reverse proxy
#
# Usage (host):
#   caddy run --config Caddyfile
# Usage (docker compose):
#   docker compose up caddy
#
# By default the upstream points to the Node app on 127.0.0.1:3000.
# Override with the APP_UPSTREAM env var (compose sets it to "app:3000").
{
	# Enable HTTP/1.1, HTTP/2, and HTTP/3 (QUIC) on the same site.
	servers {
		protocols h1 h2 h3
	}
	# Default to standard ports. `pnpm h3` overrides to 8443/8080 so it can
	# run without sudo on macOS/Linux.
	https_port {$HTTPS_PORT:443}
	http_port {$HTTP_PORT:80}
}

localhost, vee-real.localhost {
	encode zstd gzip

	# Headroom over the Node 8MB cap. Client-side WebP usually lands ~400KB,
	# but raw originals may still hit the upper bound on JS-off submits.
	request_body {
		max_size 16MB
	}

	# Photos are content-addressed by UUID so we can cache aggressively.
	@uploads path /uploads/*
	header @uploads Cache-Control "public, max-age=31536000, immutable"

	# Make the protocol observable in browser devtools and logs.
	header Alt-Svc `h3=":{$HTTPS_PORT:443}"; ma=86400`

	reverse_proxy {$APP_UPSTREAM:127.0.0.1:3000}
}
